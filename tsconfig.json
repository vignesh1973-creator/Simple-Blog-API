{
  "compilerOptions": {
    "target": "ES2022",
    "typeRoots": ["./node_modules/@types", "./src/types"],

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,
    

    "types": ["node"],

    "sourceMap": true
  },

  "include": ["src"]
}